UILib.Tab = {}
UILib.Tab.__index = UILib.Tab

function UILib.Tab.new(name)
    local self = setmetatable({}, UILib.Tab)
    self.ID = generateID()
    self.Name = name
    self.Components = {}
    self.Active = false
    
    self.Button = Instance.new("TextButton")
    self.Button.Name = "TabButton_" .. self.ID
    self.Button.Text = name
    self.Button.TextSize = 14
    self.Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    self.Button.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    self.Button.BorderSizePixel = 0
    self.Button.Font = Enum.Font.GothamMedium
    
    self.Content = createFrame(nil, "TabContent_" .. self.ID,
        Color3.fromRGB(20, 20, 20), UDim2.new(1, 0, 1, -50))
    self.Content.Position = UDim2.new(0, 0, 0, 50)
    
    local uiListLayout = Instance.new("UIListLayout")
    uiListLayout.Padding = UDim.new(0, 10)
    uiListLayout.Parent = self.Content
    
    local uiPadding = Instance.new("UIPadding")
    uiPadding.PaddingLeft = UDim.new(0, 15)
    uiPadding.PaddingRight = UDim.new(0, 15)
    uiPadding.PaddingTop = UDim.new(0, 15)
    uiPadding.Parent = self.Content
    
    return self
end

function UILib.Tab:addComponent(component)
    if component.Frame then
        component.Frame.Parent = self.Content
        table.insert(self.Components, component)
    end
    return self
end

function UILib.Tab:activate()
    self.Active = true
    self.Button.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
    self.Content.Visible = true
    return self
end

function UILib.Tab:deactivate()
    self.Active = false
    self.Button.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    self.Content.Visible = false
    return self
end

-- ==========================================
-- WINDOW COMPONENT
-- ==========================================

UILib.Window = {}
UILib.Window.__index = UILib.Window

function UILib.Window.new(title)
    local self = setmetatable({}, UILib.Window)
    self.ID = generateID()
    self.Title = title or "Window"
    self.Minimized = false
    self.Dragging = false
    self.DragStart = nil
    self.PositionStart = nil
    
    -- Main window frame
    self.Frame = createFrame(UILib.ScreenGui, "Window_" .. self.ID,
        Color3.fromRGB(20, 20, 20), UDim2.new(0, 500, 0, 600),
        UDim2.new(0.5, -250, 0.5, -300))
    createCorner(self.Frame, 10)
    
    -- Title bar
    self.TitleBar = createFrame(self.Frame, "TitleBar",
        Color3.fromRGB(30, 30, 30), UDim2.new(1, 0, 0, 35))
    createCorner(self.TitleBar, 10)
    
    -- Title text
    self.TitleLabel = createTextLabel(self.TitleBar, "Title", title, 16,
        Color3.fromRGB(255, 255, 255), Color3.fromRGB(30, 30, 30))
    self.TitleLabel.Size = UDim2.new(1, -100, 1, 0)
    self.TitleLabel.Position = UDim2.new(0, 10, 0, 0)
    self.TitleLabel.BackgroundTransparency = 1
    
    -- Minimize button
    self.MinimizeBtn = Instance.new("TextButton")
    self.MinimizeBtn.Name = "MinimizeBtn"
    self.MinimizeBtn.Text = "_"
    self.MinimizeBtn.TextSize = 18
    self.MinimizeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    self.MinimizeBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    self.MinimizeBtn.BorderSizePixel = 0
    self.MinimizeBtn.Font = Enum.Font.GothamBold
    self.MinimizeBtn.Size = UDim2.new(0, 35, 1, 0)
    self.MinimizeBtn.Position = UDim2.new(1, -75, 0, 0)
    self.MinimizeBtn.Parent = self.TitleBar
    
    self.MinimizeBtn.MouseButton1Click:Connect(function()
        self:toggleMinimize()
    end)
    
    -- Close button
    self.CloseBtn = Instance.new("TextButton")
    self.CloseBtn.Name = "CloseBtn"
    self.CloseBtn.Text = "✕"
    self.CloseBtn.TextSize = 16
    self.CloseBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    self.CloseBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    self.CloseBtn.BorderSizePixel = 0
    self.CloseBtn.Font = Enum.Font.GothamBold
    self.CloseBtn.Size = UDim2.new(0, 35, 1, 0)
    self.CloseBtn.Position = UDim2.new(1, -35, 0, 0)
    self.CloseBtn.Parent = self.TitleBar
    
    self.CloseBtn.MouseButton1Click:Connect(function()
        self:close()
    end)
    
    -- Content area with tabs
    self.ContentFrame = createFrame(self.Frame, "Content",
        Color3.fromRGB(20, 20, 20), UDim2.new(1, 0, 1, -35),
        UDim2.new(0, 0, 0, 35))
    
    -- Tab bar frame
    self.TabBar = createFrame(self.ContentFrame, "TabBar",
        Color3.fromRGB(30, 30, 30), UDim2.new(1, 0, 0, 50))
    
    local tabLayout = Instance.new("UIListLayout")
    tabLayout.FillDirection = Enum.FillDirection.Horizontal
    tabLayout.Padding = UDim.new(0, 5)
    tabLayout.Parent = self.TabBar
    
    self.Tabs = {}
    self.ActiveTabID = nil
    
    -- Dragging
    self.TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = true
            self.DragStart = game:GetService("UserInputService"):GetMouseLocation()
            self.PositionStart = self.Frame.Position
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = false
        end
    end)
    
    game:GetService("RunService").RenderStepped:Connect(function()
        if self.Dragging then
            local mouse = game:GetService("UserInputService"):GetMouseLocation()
            local delta = Vector2.new(mouse.X - self.DragStart.X, mouse.Y - self.DragStart.Y)
            self.Frame.Position = UDim2.new(
                self.PositionStart.X.Scale, self.PositionStart.X.Offset + delta.X,
                self.PositionStart.Y.Scale, self.PositionStart.Y.Offset + delta.Y
            )
        end
    end)
    
    return self
end

function UILib.Window:addTab(name)
    local tab = UILib.Tab.new(name)
    table.insert(self.Tabs, tab)
    
    tab.Button.Size = UDim2.new(0, 100, 1, 0)
    tab.Button.Parent = self.TabBar
    
    tab.Content.Parent = self.ContentFrame
    
    if self.ActiveTabID == nil then
        self:switchTab(tab.ID)
    end
    
    tab.Button.MouseButton1Click:Connect(function()
        self:switchTab(tab.ID)
    end)
    
    return tab
end

function UILib.Window:switchTab(tabID)
    for _, tab in ipairs(self.Tabs) do
        tab:deactivate()
    end
    
    for _, tab in ipairs(self.Tabs) do
        if tab.ID == tabID then
            tab:activate()
            self.ActiveTabID = tabID
            return tab
        end
    end
    
    return nil
end

function UILib.Window:toggleMinimize()
    self.Minimized = not self.Minimized
    self.ContentFrame.Visible = not self.Minimized
    if self.Minimized then
        self.Frame.Size = UDim2.new(0, 500, 0, 35)
    else
        self.Frame.Size = UDim2.new(0, 500, 0, 600)
    end
end

function UILib.Window:close()
    self.Frame:Destroy()
end

