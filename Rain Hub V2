-- CHECKBOX COMPONENT
-- ==========================================

UILib.Checkbox = {}
UILib.Checkbox.__index = UILib.Checkbox

function UILib.Checkbox.new(label, default)
    local self = setmetatable({}, UILib.Checkbox)
    self.ID = generateID()
    self.Label = label
    self.Checked = default or false
    self.OnChecked = function() end
    
    self.Frame = createFrame(nil, "Checkbox_" .. self.ID,
        Color3.fromRGB(20, 20, 20), UDim2.new(0, 250, 0, 32))
    self.Frame.BackgroundTransparency = 1
    
    -- Checkbox box
    self.CheckBox = createFrame(self.Frame, "CheckBox",
        self.Checked and Color3.fromRGB(100, 200, 255) or Color3.fromRGB(70, 70, 70),
        UDim2.new(0, 20, 0, 20), UDim2.new(0, 0, 0.5, -10))
    createCorner(self.CheckBox, 4)
    
    -- Checkmark
    if self.Checked then
        local checkmark = createTextLabel(self.CheckBox, "Checkmark", "✓", 16,
            Color3.fromRGB(255, 255, 255), Color3.fromRGB(100, 200, 255))
        checkmark.Size = UDim2.new(1, 0, 1, 0)
        checkmark.BackgroundTransparency = 1
    end
    
    -- Label
    self.LabelText = createTextLabel(self.Frame, "Label", label, 14,
        Color3.fromRGB(255, 255, 255), Color3.fromRGB(20, 20, 20))
    self.LabelText.Size = UDim2.new(1, -30, 1, 0)
    self.LabelText.Position = UDim2.new(0, 30, 0, 0)
    self.LabelText.BackgroundTransparency = 1
    
    -- Click handler
    self.CheckBox.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self:toggle()
        end
    end)
    
    return self
end

function UILib.Checkbox:toggle()
    self.Checked = not self.Checked
    self.CheckBox.BackgroundColor3 = self.Checked and Color3.fromRGB(100, 200, 255) or Color3.fromRGB(70, 70, 70)
    
    local checkmark = self.CheckBox:FindFirstChild("Checkmark")
    if self.Checked and not checkmark then
        checkmark = createTextLabel(self.CheckBox, "Checkmark", "✓", 16,
            Color3.fromRGB(255, 255, 255), Color3.fromRGB(100, 200, 255))
        checkmark.Size = UDim2.new(1, 0, 1, 0)
        checkmark.BackgroundTransparency = 1
    elseif not self.Checked and checkmark then
        checkmark:Destroy()
    end
    
    self:OnChecked(self.Checked)
    return self.Checked
end

function UILib.Checkbox:isChecked()
    return self.Checked
end

function UILib.Checkbox:onChecked(callback)
    self.OnChecked = callback
    return self
end

-- ==========================================
-- DROPDOWN COMPONENT
-- ==========================================

UILib.Dropdown = {}
UILib.Dropdown.__index = UILib.Dropdown

function UILib.Dropdown.new(options)
    local self = setmetatable({}, UILib.Dropdown)
    self.ID = generateID()
    self.Options = options or {}
    self.SelectedIndex = 1
    self.Open = false
    self.OnSelectionChanged = function() end
    
    self.Frame = createFrame(nil, "Dropdown_" .. self.ID,
        Color3.fromRGB(40, 40, 40), UDim2.new(0, 200, 0, 40))
    createCorner(self.Frame, 6)
    
    -- Display button
    self.Button = Instance.new("TextButton")
    self.Button.Name = "Button"
    self.Button.Text = self.Options[1] or "Select..."
    self.Button.TextSize = 14
    self.Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    self.Button.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    self.Button.BorderSizePixel = 0
    self.Button.Font = Enum.Font.GothamMedium
    self.Button.Size = UDim2.new(1, 0, 1, 0)
    self.Button.Parent = self.Frame
    
    createCorner(self.Button, 6)
    
    -- Dropdown list
    self.DropdownList = createFrame(nil, "DropdownList_" .. self.ID,
        Color3.fromRGB(40, 40, 40), UDim2.new(0, 200, 0, #self.Options * 35))
    self.DropdownList.Parent = nil
    self.DropdownList.Position = UDim2.new(0, 0, 0, 45)
    createCorner(self.DropdownList, 6)
    
    self:updateDropdownList()
    
    self.Button.MouseButton1Click:Connect(function()
        self:toggle()
    end)
    
    return self
end

function UILib.Dropdown:updateDropdownList()
    for _, child in ipairs(self.DropdownList:GetChildren()) do
        if child:IsA("Instance") then
            child:Destroy()
        end
    end
    
    for i, option in ipairs(self.Options) do
        local btn = Instance.new("TextButton")
        btn.Name = "Option_" .. i
        btn.Text = option
        btn.TextSize = 12
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.BackgroundColor3 = i == self.SelectedIndex and Color3.fromRGB(100, 200, 255) or Color3.fromRGB(40, 40, 40)
        btn.BorderSizePixel = 0
        btn.Font = Enum.Font.GothamMedium
        btn.Size = UDim2.new(1, 0, 0, 35)
        btn.Position = UDim2.new(0, 0, 0, (i-1) * 35)
        btn.Parent = self.DropdownList
        
        btn.MouseButton1Click:Connect(function()
            self:selectOption(i)
        end)
        
        btn.MouseEnter:Connect(function()
            btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        end)
        
        btn.MouseLeave:Connect(function()
            btn.BackgroundColor3 = i == self.SelectedIndex and Color3.fromRGB(100, 200, 255) or Color3.fromRGB(40, 40, 40)
        end)
    end
end

function UILib.Dropdown:addOption(option)
    table.insert(self.Options, option)
    self.DropdownList.Size = UDim2.new(0, 200, 0, #self.Options * 35)
    self:updateDropdownList()
    return self
end

function UILib.Dropdown:selectOption(index)
    if index > 0 and index <= #self.Options then
        self.SelectedIndex = index
        self.Button.Text = self.Options[index]
        self:toggle()
        self:OnSelectionChanged(self.Options[index], index)
        return true
    end
    return false
end

function UILib.Dropdown:toggle()
    self.Open = not self.Open
    self.DropdownList.Parent = self.Open and self.Frame.Parent or nil
    return self.Open
end

function UILib.Dropdown:onSelectionChanged(callback)
    self.OnSelectionChanged = callback
    return self
end

