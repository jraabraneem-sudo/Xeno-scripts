UILib.Toggle = {}
UILib.Toggle.__index = UILib.Toggle

function UILib.Toggle.new(label, default)
    local self = setmetatable({}, UILib.Toggle)
    self.ID = generateID()
    self.Label = label
    self.State = default or false
    self.OnStateChanged = function() end
    
    -- Main frame
    self.Frame = createFrame(nil, "Toggle_" .. self.ID,
        Color3.fromRGB(20, 20, 20), UDim2.new(0, 250, 0, 40))
    self.Frame.BackgroundTransparency = 1
    
    -- Label
    self.LabelText = createTextLabel(self.Frame, "Label", label, 14,
        Color3.fromRGB(255, 255, 255), Color3.fromRGB(20, 20, 20))
    self.LabelText.Size = UDim2.new(0, 180, 1, 0)
    self.LabelText.BackgroundTransparency = 1
    
    -- Toggle box
    self.ToggleBox = createFrame(self.Frame, "ToggleBox",
        self.State and Color3.fromRGB(76, 175, 80) or Color3.fromRGB(100, 100, 100),
        UDim2.new(0, 50, 0, 24), UDim2.new(1, -60, 0.5, -12))
    createCorner(self.ToggleBox, 12)
    
    -- Toggle button
    self.ToggleButton = Instance.new("TextButton")
    self.ToggleButton.Name = "ToggleButton"
    self.ToggleButton.Text = ""
    self.ToggleButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    self.ToggleButton.BorderSizePixel = 0
    self.ToggleButton.Size = UDim2.new(0, 20, 0, 20)
    self.ToggleButton.Position = self.State and UDim2.new(0, 25, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)
    self.ToggleButton.Parent = self.ToggleBox
    
    createCorner(self.ToggleButton, 4)
    
    self.ToggleButton.MouseButton1Click:Connect(function()
        self:toggle()
    end)
    
    return self
end

function UILib.Toggle:toggle()
    self.State = not self.State
    self.ToggleBox.BackgroundColor3 = self.State and Color3.fromRGB(76, 175, 80) or Color3.fromRGB(100, 100, 100)
    
    local tween = game:GetService("TweenService"):Create(
        self.ToggleButton,
        TweenInfo.new(0.2),
        {Position = self.State and UDim2.new(0, 25, 0.5, -10) or UDim2.new(0, 3, 0.5, -10)}
    )
    tween:Play()
    
    self:OnStateChanged(self.State)
    return self.State
end

function UILib.Toggle:getState()
    return self.State
end

function UILib.Toggle:onStateChanged(callback)
    self.OnStateChanged = callback
    return self
end

