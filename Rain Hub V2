local UILib = {}
UILib.Version = "2.0.0"
UILib.Platform = "Delta Hack"

-- ==========================================
-- CORE SETUP
-- ==========================================

local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

-- Main Screen GUI
UILib.ScreenGui = Instance.new("ScreenGui")
UILib.ScreenGui.Name = "UILib_ScreenGui"
UILib.ScreenGui.ResetOnSpawn = false
UILib.ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling

local playerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
UILib.ScreenGui.Parent = playerGui

UILib.Config = {
    Theme = "Dark",
    AnimationSpeed = 0.3,
    NotificationDuration = 3,
    DefaultFont = Enum.Font.GothamMedium,
    WindowOpacity = 0.95
}

-- ==========================================
-- UTILITIES
-- ==========================================

local function generateID()
    return "UI_" .. tostring(math.random(100000, 999999))
end

local function clamp(value, min, max)
    return math.max(min, math.min(max, value))
end

local function createFrame(parent, name, bgColor, size, position)
    local frame = Instance.new("Frame")
    frame.Name = name
    frame.BackgroundColor3 = bgColor
    frame.Size = size or UDim2.new(1, 0, 1, 0)
    frame.Position = position or UDim2.new(0, 0, 0, 0)
    frame.BorderSizePixel = 0
    frame.Parent = parent
    return frame
end

local function createTextLabel(parent, name, text, textSize, textColor, bgColor)
    local label = Instance.new("TextLabel")
    label.Name = name
    label.Text = text
    label.TextSize = textSize or 14
    label.TextColor3 = textColor or Color3.fromRGB(255, 255, 255)
    label.BackgroundColor3 = bgColor or Color3.fromRGB(20, 20, 20)
    label.BorderSizePixel = 0
    label.Font = Enum.Font.GothamMedium
    label.Parent = parent
    return label
end

local function createCorner(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 8)
    corner.Parent = parent
    return corner
end

-- ==========================================
-- NOTIFICATION SYSTEM
-- ==========================================

UILib.Notifications = {
    Queue = {},
    MaxNotifications = 5,
    Container = nil
}

function UILib.Notifications:init()
    if self.Container then return end
    
    self.Container = createFrame(UILib.ScreenGui, "NotificationsContainer", 
        Color3.fromRGB(0, 0, 0), UDim2.new(0, 400, 0, 400), 
        UDim2.new(1, -420, 0, 20))
    self.Container.BackgroundTransparency = 1
end

function UILib.Notifications:show(message, notificationType, duration)
    self:init()
    notificationType = notificationType or "info"
    duration = duration or UILib.Config.NotificationDuration
    
    if #self.Queue >= self.MaxNotifications then
        table.remove(self.Queue, 1)
    end
    
    local notification = {
        ID = generateID(),
        Message = message,
        Type = notificationType,
        Duration = duration,
        CreatedAt = os.time(),
        Visible = true,
        Frame = nil
    }
    
    -- Create notification frame
    local notifFrame = createFrame(self.Container, "Notification_" .. notification.ID,
        Color3.fromRGB(30, 30, 30), UDim2.new(1, -10, 0, 70),
        UDim2.new(0, 5, 0, #self.Queue * 80))
    
    createCorner(notifFrame, 8)
    
    -- Color based on type
    local colors = {
        success = Color3.fromRGB(76, 175, 80),
        error = Color3.fromRGB(244, 67, 54),
        warning = Color3.fromRGB(255, 152, 0),
        info = Color3.fromRGB(33, 150, 243)
    }
    
    local colorBar = createFrame(notifFrame, "ColorBar", 
        colors[notificationType] or Color3.fromRGB(100, 200, 255),
        UDim2.new(0, 5, 1, 0), UDim2.new(0, 0, 0, 0))
    
    -- Message text
    local msgLabel = createTextLabel(notifFrame, "Message", message, 14,
        Color3.fromRGB(255, 255, 255), Color3.fromRGB(30, 30, 30))
    msgLabel.Size = UDim2.new(1, -20, 1, 0)
    msgLabel.Position = UDim2.new(0, 15, 0, 0)
    msgLabel.TextWrapped = true
    msgLabel.BackgroundTransparency = 1
    
    notification.Frame = notifFrame
    table.insert(self.Queue, notification)
    
    -- Auto-hide after duration
    task.delay(duration, function()
        if notifFrame.Parent then
            notifFrame:Destroy()
        end
        self:remove(notification.ID)
    end)
    
    return notification
end

function UILib.Notifications:remove(notificationID)
    for i, notif in ipairs(self.Queue) do
        if notif.ID == notificationID then
            if notif.Frame and notif.Frame.Parent then
                notif.Frame:Destroy()
            end
            table.remove(self.Queue, i)
            return true
        end
    end
    return false
end

function UILib.Notifications:clear()
    for _, notif in ipairs(self.Queue) do
        if notif.Frame and notif.Frame.Parent then
            notif.Frame:Destroy()
        end
    end
    self.Queue = {}
end

-- ==========================================
-- BUTTON COMPONENT
-- ==========================================

UILib.Button = {}
UILib.Button.__index = UILib.Button

function UILib.Button.new(text, callback)
    local self = setmetatable({}, UILib.Button)
    self.ID = generateID()
    self.Text = text
    self.Callback = callback or function() end
    self.Enabled = true
    self.Visible = true
    
    -- Create frame
    self.Frame = createFrame(nil, "Button_" .. self.ID,
        Color3.fromRGB(50, 50, 50), UDim2.new(0, 150, 0, 40))
    
    createCorner(self.Frame, 8)
    
    -- Create text button inside
    self.Button = Instance.new("TextButton")
    self.Button.Name = "TextButton"
    self.Button.Text = text
    self.Button.TextSize = 14
    self.Button.TextColor3 = Color3.fromRGB(255, 255, 255)
    self.Button.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    self.Button.BorderSizePixel = 0
    self.Button.Font = Enum.Font.GothamMedium
    self.Button.Size = UDim2.new(1, 0, 1, 0)
    self.Button.Parent = self.Frame
    
    createCorner(self.Button, 8)
    
    -- Click handler
    self.Button.MouseButton1Click:Connect(function()
        if self.Enabled then
            self:Callback()
        end
    end)
    
    -- Hover effect
    self.Button.MouseEnter:Connect(function()
        if self.Enabled then
            self.Button.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
        end
    end)
    
    self.Button.MouseLeave:Connect(function()
        self.Button.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end)
    
    return self
end

function UILib.Button:setText(text)
    self.Text = text
    self.Button.Text = text
    return self
end

function UILib.Button:setEnabled(enabled)
    self.Enabled = enabled
    self.Button.Active = enabled
    return self
end

function UILib.Button:setSize(width, height)
    self.Frame.Size = UDim2.new(0, width, 0, height)
    return self
end

function UILib.Button:setCallback(callback)
    self.Callback = callback
    return self
end

-- ==========================================
-- SLIDER COMPONENT
-- ==========================================

UILib.Slider = {}
UILib.Slider.__index = UILib.Slider

function UILib.Slider.new(min, max, default)
    local self = setmetatable({}, UILib.Slider)
    self.ID = generateID()
    self.MinValue = min or 0
    self.MaxValue = max or 100
    self.Value = default or min
    self.OnValueChanged = function() end
    
    -- Main frame
    self.Frame = createFrame(nil, "Slider_" .. self.ID,
        Color3.fromRGB(40, 40, 40), UDim2.new(0, 200, 0, 50))
    
    -- Background bar
    self.Background = createFrame(self.Frame, "Background",
        Color3.fromRGB(40, 40, 40), UDim2.new(1, -20, 0, 6),
        UDim2.new(0, 10, 0, 15))
    createCorner(self.Background, 3)
    
    -- Fill bar
    self.Fill = createFrame(self.Background, "Fill",
        Color3.fromRGB(100, 200, 255), UDim2.new(0.5, 0, 1, 0))
    createCorner(self.Fill, 3)
    
    -- Thumb (slider handle)
    self.Thumb = createFrame(self.Background, "Thumb",
        Color3.fromRGB(100, 200, 255), UDim2.new(0, 12, 0, 20),
        UDim2.new(0.5, -6, 0, -7))
    createCorner(self.Thumb, 6)
    
    -- Value label
    self.Label = createTextLabel(self.Frame, "ValueLabel",
        tostring(self.Value), 12, Color3.fromRGB(200, 200, 200),
        Color3.fromRGB(40, 40, 40))
    self.Label.Size = UDim2.new(1, -20, 0, 20)
    self.Label.Position = UDim2.new(0, 10, 0, 25)
    self.Label.BackgroundTransparency = 1
    
    -- Dragging
    self.Thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = true
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = false
        end
    end)
    
    -- Mouse move
    game:GetService("RunService").RenderStepped:Connect(function()
        if self.Dragging then
            local mouse = game.Players.LocalPlayer:GetMouse()
            local relX = mouse.X - self.Background.AbsolutePosition.X
            local percentage = clamp(relX / self.Background.AbsoluteSize.X, 0, 1)
            local newValue = self.MinValue + (self.MaxValue - self.MinValue) * percentage
            self:setValue(newValue)
        end
    end)
    
    return self
end

function UILib.Slider:setValue(value)
    self.Value = clamp(value, self.MinValue, self.MaxValue)
    local percentage = (self.Value - self.MinValue) / (self.MaxValue - self.MinValue)
    self.Fill.Size = UDim2.new(percentage, 0, 1, 0)
    self.Thumb.Position = UDim2.new(percentage, -6, 0, -7)
    self.Label.Text = tostring(math.floor(self.Value))
    self:OnValueChanged(self.Value)
    return self
end

function UILib.Slider:getValue()
    return self.Value
end

function UILib.Slider:onValueChanged(callback)
    self.OnValueChanged = callback
    return self
end

