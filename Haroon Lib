        ProgressBar.BackgroundColor3 = Color3.fromRGB(180, 20, 20)
        ProgressBar.BorderSizePixel = 0
        ProgressBar.ZIndex = 3
        ProgressBar.Parent = NotifyFrame

        TweenService:Create(NotifyScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {Scale = 1}):Play()
        TweenService:Create(ProgressBar, TweenInfo.new(duration, Enum.EasingStyle.Linear), {Size = UDim2.new(0, 0, 0, 2)}):Play()
        
        task.delay(duration, function()
            TweenService:Create(NotifyScale, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {Scale = 0}):Play()
            task.wait(0.3)
            NotifyFrame:Destroy()
