            SldBar.Parent = SldFrame

            BarCorner.CornerRadius = UDim.new(1, 0)
            BarCorner.Parent = SldBar

            FillBar.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
            FillBar.BackgroundColor3 = Color3.fromRGB(180, 20, 20)
            FillBar.ZIndex = 2
            FillBar.Parent = SldBar

            FillCorner.CornerRadius = UDim.new(1, 0)
            FillCorner.Parent = FillBar

            Trigger.Size = UDim2.new(1, 0, 1, 0)
            Trigger.BackgroundTransparency = 1
            Trigger.Text = ""
            Trigger.ZIndex = 2
            Trigger.Parent = SldBar

            FloatingVal.Size = UDim2.new(0, 30, 0, 14)
            FloatingVal.BackgroundTransparency = 1
            FloatingVal.Text = tostring(default)
            FloatingVal.TextColor3 = Color3.fromRGB(255, 255, 255)
            FloatingVal.Font = Enum.Font.GothamBold
            FloatingVal.TextSize = 9
            FloatingVal.Visible = false
            FloatingVal.ZIndex = 3
            FloatingVal.Parent = SldFrame

            ValStroke.Color = Color3.fromRGB(0, 0, 0)
            ValStroke.Thickness = 2
            ValStroke.Parent = FloatingVal

            local Active = false

            local function UpdateSlider(input)
                local Ratio = math.clamp((input.Position.X - SldBar.AbsolutePosition.X) / SldBar.AbsoluteSize.X, 0, 1)
                local Value = math.floor(min + (max - min) * Ratio)
                FloatingVal.Text = tostring(Value)
                TweenService:Create(FillBar, TweenInfo.new(0.05), {Size = UDim2.new(Ratio, 0, 1, 0)}):Play()
                FloatingVal.Position = UDim2.new(0, math.clamp(Ratio * SldBar.AbsoluteSize.X - 6, 10, SldBar.AbsoluteSize.X - 24), 0, 10)
                callback(Value)
            end

            Trigger.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    Active = true
                    FloatingVal.Visible = true
                    UpdateSlider(input)
                end
            end)

            Trigger.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                    Active = false
                    FloatingVal.Visible = false
                end
            end)

            UserInputService.InputChanged:Connect(function(input)
                if Active and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                    UpdateSlider(input)
                end
            end)
        end

