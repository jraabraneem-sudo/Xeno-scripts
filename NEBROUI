local notifQueue = {}
local showingNotif = false

local function showNextNotif()
	if #notifQueue == 0 then
		showingNotif = false
		return
	end

	showingNotif = true
	local data = table.remove(notifQueue, 1)

	local notif = Instance.new("TextLabel")
	notif.AnchorPoint = Vector2.new(0.5, 0)
	notif.Position = UDim2.new(0.5, 0, 0, -50)
	notif.Size = UDim2.new(0, 350, 0, 40)
	notif.BackgroundColor3 = data.color
	notif.Text = data.text
	notif.TextColor3 = Color3.fromRGB(0, 0, 0)
	notif.Font = Enum.Font.GothamBold
	notif.TextSize = 18
	notif.BackgroundTransparency = 0.1
	notif.Parent = screenGui
	notif.ZIndex = 100
	Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 8)

	local stroke = Instance.new("UIStroke", notif)
	stroke.Thickness = 2
	animateRainbow(stroke)

	notif:TweenPosition(UDim2.new(0.5, 0, 0, 10), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3, true)
	task.wait(2)

	notif:TweenPosition(UDim2.new(0.5, 0, 0, -50), Enum.EasingDirection.In, Enum.EasingStyle.Quad, 0.3, true)
	task.wait(0.3)

	notif:Destroy()
	showNextNotif()
end

local function notify(text, notifType)
	local colors = {
		success = Color3.fromRGB(80, 255, 120),
		error = Color3.fromRGB(255, 80, 80),
		warning = Color3.fromRGB(255, 200, 80),
		info = windowConfig.Yellow,
	}

	table.insert(notifQueue, {
		text = tostring(text),
		color = colors[notifType or "info"] or windowConfig.Yellow,
	})

	if not showingNotif then
		showNextNotif()
	end
end

