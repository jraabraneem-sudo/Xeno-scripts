end

local function applyMinimize(state, instant)
	minimized = state
	showContent(not state)
	local target = state and MIN_SIZE or DEFAULT_SIZE
	if instant then
		mainFrame.Size = target
	else
		mainFrame:TweenSize(target, Enum.EasingDirection.Out, Enum.EasingStyle.Quint, 0.22, true)
	end
end

local function closeAnimation()
	local t = 0.23
	mainFrame:TweenSize(UDim2.new(0, 0, 0, 0), Enum.EasingDirection.In, Enum.EasingStyle.Back, t, true)
	task.wait(t)
	mainFrame.Visible = false
end

local function openAnimation()
	mainFrame.Size = UDim2.new(0, 0, 0, 0)
	mainFrame.Visible = true
	local target = minimized and MIN_SIZE or DEFAULT_SIZE
	mainFrame:TweenSize(target, Enum.EasingDirection.Out, Enum.EasingStyle.Quint, 0.35, true)
	showContent(not minimized)
end

local function selectTab(entry)
	for _, t in ipairs(tabs) do
		t.page.Visible = false
		t.button.BackgroundColor3 = windowConfig.TabBG
		t.stroke.Transparency = 0.13
		if t.rainbowAnim then
			pcall(function()
				t.rainbowAnim:Disconnect()
			end)
			t.rainbowAnim = nil
		end
		t.stroke.Color = Color3.fromRGB(255, 255, 255)
	end

	entry.page.Visible = true
	entry.button.BackgroundColor3 = windowConfig.TabBG
	entry.stroke.Transparency = 0
	entry.stroke.Color = Color3.fromRGB(255, 255, 255)

	if entry.rainbowAnim then
		pcall(function()
			entry.rainbowAnim:Disconnect()
		end)
	end
	entry.rainbowAnim = animateRainbow(entry.stroke)
	selectedTab = entry
end

