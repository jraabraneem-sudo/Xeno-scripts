-- ==========================================
-- TABS CONTAINER
-- ==========================================

UILib.TabsContainer = {}
UILib.TabsContainer.__index = UILib.TabsContainer

function UILib.TabsContainer.new()
    local self = setmetatable({}, UILib.TabsContainer)
    self.ID = generateID()
    self.Tabs = {}
    self.ActiveTabID = nil
    
    self.Style = {
        BackgroundColor = {r = 20, g = 20, b = 20},
        TabBarColor = {r = 30, g = 30, b = 30},
        BorderColor = {r = 50, g = 50, b = 50}
    }
    
    return self
end

function UILib.TabsContainer:addTab(name)
    local tab = UILib.Tab.new(name)
    table.insert(self.Tabs, tab)
    
    if self.ActiveTabID == nil then
        self:switchTab(tab.ID)
    end
    
    return tab
end

function UILib.TabsContainer:removeTab(tabID)
    for i, tab in ipairs(self.Tabs) do
        if tab.ID == tabID then
            table.remove(self.Tabs, i)
            return true
        end
    end
    return false
end

function UILib.TabsContainer:switchTab(tabID)
    for _, tab in ipairs(self.Tabs) do
        tab:deactivate()
    end
    
    for _, tab in ipairs(self.Tabs) do
        if tab.ID == tabID then
            tab:activate()
            self.ActiveTabID = tabID
            return tab
        end
    end
    
    return nil
end

function UILib.TabsContainer:getActiveTab()
    for _, tab in ipairs(self.Tabs) do
        if tab.ID == self.ActiveTabID then
            return tab
        end
    end
    return nil
end

function UILib.TabsContainer:getTabs()
    return self.Tabs
end

function UILib.TabsContainer:setStyle(styleTable)
    for key, value in pairs(styleTable) do
        self.Style[key] = value
    end
    return self
end

