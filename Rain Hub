function UILib.Window:minimize()
    if not self.Minimized then
        self.Minimized = true
        self:OnMinimize()
    end
    return self
end

function UILib.Window:maximize()
    if self.Minimized then
        self.Minimized = false
        self:OnMaximize()
    end
    return self
end

function UILib.Window:toggleMinimize()
    if self.Minimized then
        return self:maximize()
    else
        return self:minimize()
    end
end

function UILib.Window:close()
    self.Visible = false
    self:OnClose()
    return self
end

function UILib.Window:open()
    self.Visible = true
    return self
end

function UILib.Window:setTitle(title)
