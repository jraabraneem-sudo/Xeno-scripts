local UILib = {}
UILib.Version = "1.0.0"
UILib.Platform = "Delta Hack"

-- ==========================================
-- CONFIGURATION
-- ==========================================

UILib.Config = {
    Theme = "Dark",
    AnimationSpeed = 0.3,
    NotificationDuration = 3,
    DefaultFont = "Arial",
    WindowOpacity = 0.95
}

-- ==========================================
-- UTILITIES
-- ==========================================

local function generateID()
    return "UI_" .. tostring(math.random(100000, 999999))
end

local function clamp(value, min, max)
    return math.max(min, math.min(max, value))
end

-- ==========================================
-- NOTIFICATION SYSTEM
-- ==========================================

UILib.Notifications = {
    Queue = {},
    MaxNotifications = 5,
    NotificationTypes = {
        SUCCESS = "success",
        WARNING = "warning",
        ERROR = "error",
        INFO = "info"
    }
}

function UILib.Notifications:show(message, notificationType, duration)
    notificationType = notificationType or self.NotificationTypes.INFO
    duration = duration or UILib.Config.NotificationDuration
    
    -- Remove oldest if max reached
    if #self.Queue >= self.MaxNotifications then
        table.remove(self.Queue, 1)
    end
    
    local notification = {
        ID = generateID(),
        Message = message,
        Type = notificationType,
        Duration = duration,
        CreatedAt = os.time(),
        Visible = true,
        Position = #self.Queue + 1
    }
    
    table.insert(self.Queue, notification)
    
    -- Auto-hide after duration
    task.delay(duration, function()
        self:remove(notification.ID)
    end)
    
    return notification
end

function UILib.Notifications:remove(notificationID)
    for i, notif in ipairs(self.Queue) do
        if notif.ID == notificationID then
            table.remove(self.Queue, i)
            return true
        end
    end
    return false
end

function UILib.Notifications:clear()
    self.Queue = {}
end

function UILib.Notifications:getAll()
    return self.Queue
end

-- ==========================================
-- BUTTON COMPONENT
-- ==========================================

UILib.Button = {}
UILib.Button.__index = UILib.Button

function UILib.Button.new(text, callback)
    local self = setmetatable({}, UILib.Button)
    self.ID = generateID()
    self.Text = text
    self.Callback = callback or function() end
    self.Enabled = true
    self.Visible = true
    self.Hovered = false
    self.Clicked = false
    
    self.Style = {
        BackgroundColor = {r = 50, g = 50, b = 50},
        HoverColor = {r = 70, g = 70, b = 70},
        ClickColor = {r = 40, g = 40, b = 40},
        TextColor = {r = 255, g = 255, b = 255},
        BorderColor = {r = 80, g = 80, b = 80},
        CornerRadius = 8,
        Padding = 10,
        Height = 40,
        Width = 150,
        TextSize = 14
    }
    
    return self
end

function UILib.Button:click()
    if self.Enabled then
        self.Clicked = true
        self:Callback()
        task.delay(0.1, function() self.Clicked = false end)
        return true
    end
    return false
end

function UILib.Button:setEnabled(enabled)
    self.Enabled = enabled
    return self
end

function UILib.Button:setText(text)
    self.Text = text
    return self
end

function UILib.Button:setStyle(styleTable)
    for key, value in pairs(styleTable) do
        self.Style[key] = value
    end
    return self
end

function UILib.Button:setCallback(callback)
    self.Callback = callback
    return self
end

