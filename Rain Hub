UILib.Slider = {}
UILib.Slider.__index = UILib.Slider

function UILib.Slider.new(min, max, default)
    local self = setmetatable({}, UILib.Slider)
    self.ID = generateID()
    self.MinValue = min or 0
    self.MaxValue = max or 100
    self.Value = default or min
    self.Dragging = false
    self.OnValueChanged = function() end
    
    self.Style = {
        BackgroundColor = {r = 40, g = 40, b = 40},
        ForegroundColor = {r = 100, g = 200, b = 255},
        ThumbColor = {r = 100, g = 200, b = 255},
        Height = 6,
        Width = 200,
        ThumbSize = 12,
        CornerRadius = 3
    }
    
    return self
end

function UILib.Slider:setValue(value)
    self.Value = clamp(value, self.MinValue, self.MaxValue)
    self:OnValueChanged(self.Value)
    return self
end

function UILib.Slider:getValue()
    return self.Value
end

function UILib.Slider:getPercentage()
    return ((self.Value - self.MinValue) / (self.MaxValue - self.MinValue)) * 100
end

function UILib.Slider:setRange(min, max)
    self.MinValue = min
    self.MaxValue = max
    self:setValue(self.Value)
    return self
end

function UILib.Slider:setStyle(styleTable)
    for key, value in pairs(styleTable) do
        self.Style[key] = value
    end
    return self
end

function UILib.Slider:onValueChanged(callback)
    self.OnValueChanged = callback
    return self
end

