-- // --- 2. FAST MODE (FPS BOOST) ---
local FastMode = false
local OriginalSettings = {}

local function ToggleFastMode(state)
    if state then
        for _, v in pairs(Workspace:GetDescendants()) do
            if v:IsA("BasePart") and v.Transparency ~= 1 then
                OriginalSettings[v] = {Material = v.Material, Shadow = v.CastShadow}
                v.Material = Enum.Material.Plastic
                v.CastShadow = false
            elseif v:IsA("Decal") or v:IsA("Texture") then
                OriginalSettings[v] = v.Transparency
                v.Transparency = 1
            end
        end
        Lighting.GlobalShadows = false
    else
        for obj, data in pairs(OriginalSettings) do
            if obj and obj.Parent then
                if obj:IsA("BasePart") then
                    obj.Material = data.Material
                    obj.CastShadow = data.Shadow
                else
                    obj.Transparency = data
                end
            end
        end
        Lighting.GlobalShadows = true
        OriginalSettings = {}
    end
end

SettingsTab:AddToggle({
    Name = "Fast Mode",
    Default = false,
    Callback = function(state)
        FastMode = state
        ToggleFastMode(state)
    end
})

-- // --- 3. AUTO FARM CHEST ---
local AutoChest = false
local ChestSpeed = 350

local function SmartTween(targetPos)
    local dist = (Root.Position - targetPos).Magnitude
    if dist < 8 then return end
    
    local tween = TweenService:Create(Root, TweenInfo.new(dist / ChestSpeed, Enum.EasingStyle.Linear), {CFrame = CFrame.new(targetPos)})
    tween:Play()
    
    -- نظام Noclip أثناء الحركة
    local noclip = RunService.Stepped:Connect(function()
        for _, v in pairs(Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end)
    
    tween.Completed:Wait()
    noclip:Disconnect()
end

task.spawn(function()
    while task.wait(0.5) do
        if AutoChest then
            pcall(function()
                local Chests = Workspace:FindFirstChild("ChestModels") or Workspace:FindFirstChild("Chests")
                if Chests then
                    local target = nil
                    local minDist = math.huge
                    
                    for _, v in pairs(Chests:GetChildren()) do
                        if v:IsA("Model") and (v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")) then
                            local part = v.PrimaryPart or v:FindFirstChildWhichIsA("BasePart")
                            local d = (Root.Position - part.Position).Magnitude
                            if d < minDist then
                                minDist = d
                                target = part
                            end
                        end
                    end
                    
                    if target then SmartTween(target.Position) end
                end
            end)
        end
    end
end)

