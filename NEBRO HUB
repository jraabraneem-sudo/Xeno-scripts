    Speed = 300
}

-- // --- FUNCTIONS ---

-- جلب معرف الجلسة لضمان القتل السريع
local function GetSessionID()
    local success, result = pcall(function()
        local SendHitsToServer = getrenv()._G.SendHitsToServer
        local CombatThread = getupvalues(SendHitsToServer)[1]
        return tostring(Player.UserId):sub(2,4)..tostring(CombatThread):sub(11,15)
    end)
    return success and result or "INVALID"
end

-- نظام التنقل السلس (Smart Tween)
local function SmartTween(targetCF)
    local dist = (Root.Position - targetCF.Position).Magnitude
    if dist < 10 then return end
    
    if Config.CurrentTween then Config.CurrentTween:Cancel() end
    
    Config.CurrentTween = TweenService:Create(Root, TweenInfo.new(dist / Config.Speed, Enum.EasingStyle.Linear), {CFrame = targetCF})
    Config.CurrentTween:Play()
    
    -- انتظار الوصول أو إلغاء التوغل
    repeat 
        task.wait() 
        Root.Velocity = Vector3.zero 
    until (Root.Position - targetCF.Position).Magnitude < 15 or not Config.AutoRaid
    
    if Config.CurrentTween then Config.CurrentTween:Cancel() end
end

-- تجهيز أسلوب القتال تلقائياً
local function EquipCombat()
    local CombatStyles = {"Godhuman", "Sanguine Art", "Death Step", "Electric Claw", "Dragon Talon", "Superhuman", "Sharkman Karate", "Electric", "Black Leg", "Fishman Karate", "Combat"}
    for _, style in ipairs(CombatStyles) do
        local tool = Player.Backpack:FindFirstChild(style) or Character:FindFirstChild(style)
        if tool then
            if tool.Parent ~= Character then Humanoid:EquipTool(tool) end
            return
        end
    end
end

-- نظام Kill Aura (ضرب فائق السرعة)
local function KillAura(target)
    if not target or not target:FindFirstChild("HumanoidRootPart") then return end
    pcall(function()
        local Net = ReplicatedStorage.Modules.Net
        Net["RE/RegisterAttack"]:FireServer(0)
        Net["RE/RegisterHit"]:FireServer(target.HumanoidRootPart, {}, nil, GetSessionID())
    end)
end

