-- Session ID for Security
local function GetSessionID()
    local success, result = pcall(function()
        local SendHitsToServer = getrenv()._G.SendHitsToServer
        local CombatThread = getupvalues(SendHitsToServer)[1]
        return tostring(Player.UserId):sub(2,4)..tostring(CombatThread):sub(11,15)
    end)
    return success and result or "INVALID_SESSION"
end

-- Auto Haki Logic
local function ApplyHaki()
    if AutoFarm and not HakiUsed then
        pcall(function()
            CommF:InvokeServer("Buso")
            HakiUsed = true
        end)
    end
end

-- Smart Weapon Equipping
local function EquipWeapon()
    local TargetList = (SelectedWeaponType == "Combat") and FightingStyles or SwordsList
    for _, weaponName in ipairs(TargetList) do
        local tool = Player.Backpack:FindFirstChild(weaponName) or Character:FindFirstChild(weaponName)
        if tool then
            if tool.Parent ~= Character then
                Humanoid:EquipTool(tool)
            end
            return tool
        end
    end
end

-- Smooth Tween (No High Fly)
local function SmartTween(targetCFrame)
    local distance = (Root.Position - targetCFrame.Position).Magnitude
    if distance < 5 then return end

    -- Noclip Enable
    for _, v in pairs(Character:GetDescendants()) do
        if v:IsA("BasePart") then v.CanCollide = false end
    end

    local tweenInfo = TweenInfo.new(distance / 150, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(Root, tweenInfo, {CFrame = targetCFrame})
    
    tween:Play()
    tween.Completed:Wait()
end

