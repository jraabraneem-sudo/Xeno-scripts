-- ==========================================
-- DROPDOWN
-- ==========================================

UILib.Dropdown = {}
UILib.Dropdown.__index = UILib.Dropdown

function UILib.Dropdown.new(options)
    local self = setmetatable({}, UILib.Dropdown)
    self.ID = ID()
    self.Options = options or {}
    self.Selected = 1
    self.Open = false
    self.OnChanged = function() end
    
    self.Frame = frame(nil, "Dropdown_" .. self.ID, Color3.fromRGB(40,40,40), UDim2.new(0, 180, 0, 32))
    
    self.Button = Instance.new("TextButton")
    self.Button.Text = self.Options[1] or "Select..."
    self.Button.TextSize = 12
    self.Button.TextColor3 = Color3.fromRGB(255,255,255)
    self.Button.BackgroundColor3 = Color3.fromRGB(40,40,40)
    self.Button.BorderSizePixel = 0
    self.Button.Font = Enum.Font.GothamMedium
    self.Button.Size = UDim2.new(1, 0, 1, 0)
    self.Button.Parent = self.Frame
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = self.Button
    
    self.List = frame(nil, "List_" .. self.ID, Color3.fromRGB(40,40,40), 
        UDim2.new(0, 180, 0, #self.Options * 28))
    self.List.Position = UDim2.new(0, 0, 0, 35)
    
    self:updateList()
    
    self.Button.MouseButton1Click:Connect(function()
        self:toggle()
    end)
    
    return self
end

function UILib.Dropdown:updateList()
    for _, child in ipairs(self.List:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    
    for i, opt in ipairs(self.Options) do
        local btn = Instance.new("TextButton")
        btn.Text = opt
        btn.TextSize = 11
        btn.TextColor3 = Color3.fromRGB(255,255,255)
        btn.BackgroundColor3 = i == self.Selected and Color3.fromRGB(100,200,255) or Color3.fromRGB(40,40,40)
        btn.BorderSizePixel = 0
        btn.Font = Enum.Font.GothamMedium
        btn.Size = UDim2.new(1, 0, 0, 28)
        btn.Position = UDim2.new(0, 0, 0, (i-1) * 28)
        btn.Parent = self.List
        
        btn.MouseButton1Click:Connect(function()
            self.Selected = i
            self.Button.Text = opt
            self:toggle()
            self:OnChanged(opt, i)
        end)
    end
end

function UILib.Dropdown:addOption(option)
    table.insert(self.Options, option)
    self.List.Size = UDim2.new(0, 180, 0, #self.Options * 28)
    self:updateList()
    return self
end

function UILib.Dropdown:toggle()
    self.Open = not self.Open
    self.List.Parent = self.Open and self.Frame.Parent or nil
    return self.Open
end

function UILib.Dropdown:onChanged(callback)
    self.OnChanged = callback
    return self
end

