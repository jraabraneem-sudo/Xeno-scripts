-- ==========================================
-- WINDOW
-- ==========================================

UILib.Window = {}
UILib.Window.__index = UILib.Window

function UILib.Window.new(title)
    local self = setmetatable({}, UILib.Window)
    self.ID = ID()
    self.Dragging = false
    self.Minimized = false
    
    self.Frame = frame(ScreenGui, "Window_" .. self.ID, Color3.fromRGB(20,20,20), 
        UDim2.new(0, 420, 0, 480), UDim2.new(0.5, -210, 0.5, -240))
    
    local titleBar = frame(self.Frame, "TitleBar", Color3.fromRGB(30,30,30), UDim2.new(1, 0, 0, 30))
    titleBar.BorderSizePixel = 0
    
    local titleLbl = label(titleBar, title, 13, Color3.fromRGB(255,255,255), Color3.fromRGB(30,30,30), 1)
    titleLbl.Size = UDim2.new(1, -65, 1, 0)
    titleLbl.Position = UDim2.new(0, 8, 0, 0)
    
    local minBtn = Instance.new("TextButton")
    minBtn.Text = "_"
    minBtn.TextSize = 14
    minBtn.TextColor3 = Color3.fromRGB(255,255,255)
    minBtn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    minBtn.BorderSizePixel = 0
    minBtn.Font = Enum.Font.GothamBold
    minBtn.Size = UDim2.new(0, 30, 1, 0)
    minBtn.Position = UDim2.new(1, -65, 0, 0)
    minBtn.Parent = titleBar
    
    local closeBtn = Instance.new("TextButton")
    closeBtn.Text = "✕"
    closeBtn.TextSize = 12
    closeBtn.TextColor3 = Color3.fromRGB(255,255,255)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200,50,50)
    closeBtn.BorderSizePixel = 0
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.Size = UDim2.new(0, 30, 1, 0)
    closeBtn.Position = UDim2.new(1, -30, 0, 0)
    closeBtn.Parent = titleBar
    
    local content = frame(self.Frame, "Content", Color3.fromRGB(20,20,20), UDim2.new(1, 0, 1, -30), UDim2.new(0, 0, 0, 30))
    
    local tabBar = frame(content, "TabBar", Color3.fromRGB(25,25,25), UDim2.new(1, 0, 0, 40))
    
    local tabLayout = Instance.new("UIListLayout")
    tabLayout.FillDirection = Enum.FillDirection.Horizontal
    tabLayout.Padding = UDim.new(0, 3)
    tabLayout.Parent = tabBar
    
    self.Tabs = {}
    
    minBtn.MouseButton1Click:Connect(function()
        self.Minimized = not self.Minimized
        content.Visible = not self.Minimized
        self.Frame.Size = self.Minimized and UDim2.new(0, 420, 0, 30) or UDim2.new(0, 420, 0, 480)
    end)
    
    closeBtn.MouseButton1Click:Connect(function()
        self.Frame:Destroy()
    end)
    
    -- Dragging
    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = true
            self.DragStart = game:GetService("UserInputService"):GetMouseLocation()
            self.PosStart = self.Frame.Position
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = false
        end
    end)
    
    RunService.RenderStepped:Connect(function()
        if self.Dragging then
            local mouse = game:GetService("UserInputService"):GetMouseLocation()
            local delta = Vector2.new(mouse.X - self.DragStart.X, mouse.Y - self.DragStart.Y)
            self.Frame.Position = UDim2.new(
                self.PosStart.X.Scale, self.PosStart.X.Offset + delta.X,
                self.PosStart.Y.Scale, self.PosStart.Y.Offset + delta.Y
            )
        end
    end)
    
    self.TabBar = tabBar
    self.Content = content
    
    return self
end

function UILib.Window:addTab(name)
    local tab = UILib.Tab.new(name)
    table.insert(self.Tabs, tab)
    
    tab.Button.Size = UDim2.new(0, 90, 1, 0)
    tab.Button.Parent = self.TabBar
    
    tab.Content.Parent = self.Content
    
    if #self.Tabs == 1 then
        self:switchTab(tab.ID)
    end
    
    tab.Button.MouseButton1Click:Connect(function()
        self:switchTab(tab.ID)
    end)
    
    return tab
end

function UILib.Window:switchTab(tabID)
    for _, tab in ipairs(self.Tabs) do
        tab:deactivate()
    end
    
    for _, tab in ipairs(self.Tabs) do
        if tab.ID == tabID then
            tab:activate()
            return tab
        end
    end
end

