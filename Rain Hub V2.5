-- ==========================================
-- UILib - Compact UI Library for Delta Hack
-- Version: 2.1.0 - Optimized & Auto-Load
-- ==========================================

local UILib = {}
UILib.Version = "2.1.0"

local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

-- ==========================================
-- QUICK SETUP
-- ==========================================

local playerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "UILib"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
ScreenGui.Parent = playerGui

UILib.ScreenGui = ScreenGui
UILib.Notifications = {Queue = {}}

-- ==========================================
-- HELPER FUNCTIONS
-- ==========================================

local function ID()
    return "UI_" .. math.random(100000, 999999)
end

local function clamp(v, min, max)
    return math.max(min, math.min(max, v))
end

local function frame(parent, name, color, size, pos)
    local f = Instance.new("Frame")
    f.Name = name
    f.BackgroundColor3 = color
    f.Size = size or UDim2.new(1, 0, 1, 0)
    f.Position = pos or UDim2.new(0, 0, 0, 0)
    f.BorderSizePixel = 0
    f.Parent = parent
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = f
    return f
end

local function label(parent, text, size, color, bg, trans)
    local l = Instance.new("TextLabel")
    l.Text = text
    l.TextSize = size or 13
    l.TextColor3 = color or Color3.fromRGB(255, 255, 255)
    l.BackgroundColor3 = bg or Color3.fromRGB(20, 20, 20)
    l.BackgroundTransparency = trans or 0
    l.BorderSizePixel = 0
    l.Font = Enum.Font.GothamMedium
    l.Parent = parent
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = l
    return l
end

-- ==========================================
-- NOTIFICATIONS
-- ==========================================

UILib.Notifications.init = function(self)
    if self.Container then return end
    self.Container = frame(ScreenGui, "NotifContainer", Color3.fromRGB(0,0,0), 
        UDim2.new(0, 350, 0, 300), UDim2.new(1, -370, 0, 10))
    self.Container.BackgroundTransparency = 1
end

function UILib.Notifications:show(msg, typ, dur)
    self:init()
    typ = typ or "info"
    dur = dur or 3
    
    local colors = {
        success = Color3.fromRGB(76, 175, 80),
        error = Color3.fromRGB(244, 67, 54),
        warning = Color3.fromRGB(255, 152, 0),
        info = Color3.fromRGB(33, 150, 243)
    }
    
    local nf = frame(self.Container, "Notif_" .. ID(), Color3.fromRGB(30,30,30), 
        UDim2.new(1, -10, 0, 55), UDim2.new(0, 5, 0, #self.Queue * 60))
    
    local bar = frame(nf, "Bar", colors[typ] or Color3.fromRGB(100,200,255), 
        UDim2.new(0, 4, 1, 0), UDim2.new(0, 0, 0, 0))
    bar.BorderSizePixel = 0
    
    local lbl = label(nf, msg, 12, Color3.fromRGB(255,255,255), Color3.fromRGB(30,30,30), 1)
    lbl.Size = UDim2.new(1, -20, 1, 0)
    lbl.Position = UDim2.new(0, 12, 0, 0)
    lbl.TextWrapped = true
    lbl.TextXAlignment = Enum.TextXAlignment.Left
    
    table.insert(self.Queue, nf)
    
    task.delay(dur, function()
        if nf.Parent then nf:Destroy() end
        table.remove(self.Queue, 1)
    end)
end

-- ==========================================
-- BUTTON
-- ==========================================

UILib.Button = {}
UILib.Button.__index = UILib.Button

function UILib.Button.new(text, callback)
    local self = setmetatable({}, UILib.Button)
    self.ID = ID()
    self.Frame = frame(nil, "Btn_" .. self.ID, Color3.fromRGB(50,50,50), UDim2.new(0, 130, 0, 32))
    
    local btn = Instance.new("TextButton")
    btn.Text = text
    btn.TextSize = 12
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.BackgroundColor3 = Color3.fromRGB(50,50,50)
    btn.BorderSizePixel = 0
    btn.Font = Enum.Font.GothamMedium
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.Parent = self.Frame
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    
    btn.MouseButton1Click:Connect(callback or function() end)
    
    btn.MouseEnter:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
    end)
    
    btn.MouseLeave:Connect(function()
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    end)
    
    self.Button = btn
    return self
end

function UILib.Button:setText(text)
    self.Button.Text = text
    return self
end

-- ==========================================
-- SLIDER
-- ==========================================

UILib.Slider = {}
UILib.Slider.__index = UILib.Slider

function UILib.Slider.new(min, max, default)
    local self = setmetatable({}, UILib.Slider)
    self.ID = ID()
    self.Min = min or 0
    self.Max = max or 100
    self.Value = default or min
    self.OnChanged = function() end
    
    self.Frame = frame(nil, "Slider_" .. self.ID, Color3.fromRGB(30,30,30), UDim2.new(0, 200, 0, 45))
    
    local bg = frame(self.Frame, "BG", Color3.fromRGB(50,50,50), UDim2.new(1, -20, 0, 5), UDim2.new(0, 10, 0, 15))
    
    self.Fill = frame(bg, "Fill", Color3.fromRGB(100,200,255), UDim2.new(0.5, 0, 1, 0))
    
    self.Thumb = frame(bg, "Thumb", Color3.fromRGB(100,200,255), UDim2.new(0, 10, 0, 15), UDim2.new(0.5, -5, 0, -5))
    
    self.Label = label(self.Frame, "50", 11, Color3.fromRGB(200,200,200), Color3.fromRGB(30,30,30), 1)
    self.Label.Size = UDim2.new(1, -20, 0, 15)
    self.Label.Position = UDim2.new(0, 10, 0, 25)
    
    self.Thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = true
        end
    end)
    
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self.Dragging = false
        end
    end)
    
    RunService.RenderStepped:Connect(function()
        if self.Dragging then
            local mouse = game.Players.LocalPlayer:GetMouse()
            local rel = mouse.X - bg.AbsolutePosition.X
            local pct = clamp(rel / bg.AbsoluteSize.X, 0, 1)
            local val = self.Min + (self.Max - self.Min) * pct
            self:setValue(val)
        end
    end)
    
    return self
end

function UILib.Slider:setValue(value)
    self.Value = clamp(value, self.Min, self.Max)
    local pct = (self.Value - self.Min) / (self.Max - self.Min)
    self.Fill.Size = UDim2.new(pct, 0, 1, 0)
    self.Thumb.Position = UDim2.new(pct, -5, 0, -5)
    self.Label.Text = tostring(math.floor(self.Value))
    self:OnChanged(self.Value)
    return self
end

function UILib.Slider:getValue()
    return self.Value
end

function UILib.Slider:onChanged(callback)
    self.OnChanged = callback
    return self
end

-- ==========================================
-- TOGGLE
-- ==========================================

UILib.Toggle = {}
UILib.Toggle.__index = UILib.Toggle

function UILib.Toggle.new(label, default)
    local self = setmetatable({}, UILib.Toggle)
    self.ID = ID()
    self.State = default or false
    self.OnChanged = function() end
    
    self.Frame = frame(nil, "Toggle_" .. self.ID, Color3.fromRGB(20,20,20), UDim2.new(0, 220, 0, 28))
    self.Frame.BackgroundTransparency = 1
    
    local lbl = label(self.Frame, label, 12, Color3.fromRGB(255,255,255), Color3.fromRGB(20,20,20), 1)
    lbl.Size = UDim2.new(0, 160, 1, 0)
    lbl.BackgroundTransparency = 1
    
    self.Box = frame(self.Frame, "Box", self.State and Color3.fromRGB(76,175,80) or Color3.fromRGB(100,100,100), 
        UDim2.new(0, 45, 0, 20), UDim2.new(1, -50, 0.5, -10))
    
    self.Toggle = frame(self.Box, "Toggle", Color3.fromRGB(255,255,255), UDim2.new(0, 18, 0, 18), 
        self.State and UDim2.new(0, 23, 0, 1) or UDim2.new(0, 1, 0, 1))
    
    self.Box.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self:toggle()
        end
    end)
    
    return self
end

function UILib.Toggle:toggle()
    self.State = not self.State
    self.Box.BackgroundColor3 = self.State and Color3.fromRGB(76,175,80) or Color3.fromRGB(100,100,100)
    
    TweenService:Create(self.Toggle, TweenInfo.new(0.15), {
        Position = self.State and UDim2.new(0, 23, 0, 1) or UDim2.new(0, 1, 0, 1)
    }):Play()
    
    self:OnChanged(self.State)
    return self.State
end

function UILib.Toggle:getState()
    return self.State
end

function UILib.Toggle:onChanged(callback)
    self.OnChanged = callback
    return self
end

-- ==========================================
-- CHECKBOX
-- ==========================================

UILib.Checkbox = {}
UILib.Checkbox.__index = UILib.Checkbox

function UILib.Checkbox.new(label, default)
    local self = setmetatable({}, UILib.Checkbox)
    self.ID = ID()
    self.Checked = default or false
    self.OnChanged = function() end
    
    self.Frame = frame(nil, "Checkbox_" .. self.ID, Color3.fromRGB(20,20,20), UDim2.new(0, 220, 0, 24))
    self.Frame.BackgroundTransparency = 1
    
    self.Box = frame(self.Frame, "Box", self.Checked and Color3.fromRGB(100,200,255) or Color3.fromRGB(70,70,70), 
        UDim2.new(0, 16, 0, 16), UDim2.new(0, 0, 0.5, -8))
    
    if self.Checked then
        local chk = label(self.Box, "✓", 14, Color3.fromRGB(255,255,255), Color3.fromRGB(100,200,255), 1)
        chk.Size = UDim2.new(1, 0, 1, 0)
    end
    
    local lbl = label(self.Frame, label, 12, Color3.fromRGB(255,255,255), Color3.fromRGB(20,20,20), 1)
    lbl.Size = UDim2.new(1, -26, 1, 0)
    lbl.Position = UDim2.new(0, 22, 0, 0)
    
    self.Box.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            self:toggle()
        end
    end)
    
    return self
end

function UILib.Checkbox:toggle()
    self.Checked = not self.Checked
    self.Box.BackgroundColor3 = self.Checked and Color3.fromRGB(100,200,255) or Color3.fromRGB(70,70,70)
    
    local chk = self.Box:FindFirstChild("✓")
    if self.Checked and not chk then
        local check = label(self.Box, "✓", 14, Color3.fromRGB(255,255,255), Color3.fromRGB(100,200,255), 1)
        check.Size = UDim2.new(1, 0, 1, 0)
    elseif not self.Checked and chk then
        chk:Destroy()
    end
    
    self:OnChanged(self.Checked)
    return self.Checked
end

function UILib.Checkbox:isChecked()
    return self.Checked
end

function UILib.Checkbox:onChanged(callback)
    self.OnChanged = callback
    return self
end

